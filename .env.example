# Copy this file to .env and fill in your values
# Never commit .env to git — it's in .gitignore

# Anthropic Claude API key — required for the AI Audit Tool (/audit page)
# Get yours at: https://console.anthropic.com
# Also add as GitHub Actions secret: Settings → Secrets → PUBLIC_CLAUDE_API_KEY
PUBLIC_CLAUDE_API_KEY=sk-ant-your-key-here

# Password for the /audit page — internal use only
# Also add as GitHub Actions secret: Settings → Secrets → AUDIT_PAGE_PASSWORD
AUDIT_PAGE_PASSWORD=your-strong-password-here
