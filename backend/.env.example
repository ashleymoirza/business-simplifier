# ── LLM Backend ────────────────────────────────────────────────────────────
# Which LLM provider to use for report generation
# Options: fcc (default) | openrouter | groq
LLM_PROVIDER=fcc

# free-claude-code server (already installed — runs at localhost:9090)
# No extra config needed for fcc — it manages the Anthropic key itself.
FCC_API_KEY=dummy

# OpenRouter free tier (alternative — sign up at openrouter.ai, free models available)
# OPENROUTER_API_KEY=sk-or-...

# Groq free tier (alternative — sign up at console.groq.com, fast free inference)
# GROQ_API_KEY=gsk_...

# Override the model used (optional — defaults to provider's default)
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Audit page password (matches audit.astro) ───────────────────────────────
AUDIT_PAGE_PASSWORD=changeme

# ── WhatsApp CTA (update with your real number) ────────────────────────────
WA_OWNER_NUMBER=27000000000
