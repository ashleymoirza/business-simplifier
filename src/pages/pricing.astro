---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingSection from '../components/PricingSection.astro';
import AIChat from '../components/AIChat.astro';
---

<BaseLayout
  title="Pricing"
  description="Transparent AI consultation pricing for SA and international markets. Start with a free 1-hour session. No hidden fees."
>
  <section class="bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">Simple, Transparent Pricing</h1>
      <p class="mt-4 text-xl text-brand-100 max-w-2xl mx-auto">
        SA-market and international pricing. Start free, scale as you grow.
      </p>
    </div>
  </section>

  <PricingSection />

  {/* FAQ */}
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'What happens in the free consultation?', a: 'We spend 1 hour understanding your business, identifying processes where AI can have the most impact, and giving you a clear roadmap — no commitment required.' },
          { q: 'How long does a typical project take?', a: 'Most single-solution projects (chatbots, automation) are delivered in 5-10 days. Full integrations take 3-6 weeks depending on scope.' },
          { q: 'Do I need technical knowledge?', a: 'No. We handle all the technical work. You just need to know your business processes and pain points.' },
          { q: 'What if I\'m not satisfied?', a: 'We iterate until you\'re happy. Our Professional and Enterprise plans include unlimited revisions.' },
          { q: 'Do you offer ongoing support?', a: 'Yes. All paid plans include email support. Professional and Enterprise include priority support with dedicated engineers.' },
        ].map((faq) => (
          <div x-data="{ open: false }" class="border border-neutral-200 rounded-lg">
            <button
              @click="open = !open"
              class="w-full flex items-center justify-between px-5 py-4 text-left"
            >
              <span class="font-medium text-neutral-900">{faq.q}</span>
              <svg
                x-show="!open" class="w-5 h-5 text-neutral-400 shrink-0"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
              </svg>
              <svg
                x-show="open" class="w-5 h-5 text-neutral-400 shrink-0"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6"/>
              </svg>
            </button>
            <div x-show="open" x-transition class="px-5 pb-4">
              <p class="text-sm text-neutral-600">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <AIChat prompt="Questions about pricing? Ask me!" />
</BaseLayout>