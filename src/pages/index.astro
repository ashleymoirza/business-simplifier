---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ServicesSection from '../components/ServicesSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import PricingSection from '../components/PricingSection.astro';
import AIChat from '../components/AIChat.astro';
import { organizationSchema } from '../lib/seo';
---

<BaseLayout
  title="Business Simplifier — AI That Cuts Costs & Saves Time"
  description="Save R135K/year on average with AI. Free 1-hour consultation. Chatbots, automation, analytics — practical AI for South African SMEs."
>
  <Hero />
  <TrustBar />

  {/* Services Overview */}
  <ServicesSection />

  {/* Why AI Now — Social Proof Section */}
  <section class="py-16 sm:py-20 bg-brand-950 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold">Why AI Now?</h2>
        <p class="mt-4 text-lg text-brand-200">
          Businesses that adopt AI today gain a compounding advantage. Those that wait will play catch-up.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="text-4xl font-extrabold text-accent-400">R135K</div>
          <p class="mt-2 text-sm text-brand-200">Average annual savings for businesses using AI (Thryv 2025)</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-accent-400">20+ hrs</div>
          <p class="mt-2 text-sm text-brand-200">Time saved per month — reinvested into growth (SBEC 2025)</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-accent-400">55%</div>
          <p class="mt-2 text-sm text-brand-200">of SA SMEs now using AI — up 41% from 2024 (Thryv 2025)</p>
        </div>
      </div>
    </div>
  </section>

  {/* Testimonials */}
  <TestimonialsSection />

  {/* AI Audit Tool CTA */}
  <section class="py-16 sm:py-20 bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-5 text-xs font-semibold text-accent-300 bg-accent-900/30 rounded-full border border-accent-700/30">
        <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse-subtle"></span>
        New — Instant AI Audit Tool
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
        Get Your Free AI Audit Report in 60 Seconds
      </h2>
      <p class="mt-4 text-lg text-brand-100 max-w-2xl mx-auto leading-relaxed">
        Paste in your business details. Our AI analyses your industry, team size, and biggest pain points — then returns a personalised implementation plan with real rand ROI estimates.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-6 text-sm text-brand-300 mb-8">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          No email required
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Instant results
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Downloadable PDF report
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Completely free
        </span>
      </div>
      <a
        href="/audit"
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-bold text-brand-950 bg-accent-400 hover:bg-accent-300 rounded-xl transition-colors shadow-xl hover:shadow-2xl hover:scale-[1.02] active:scale-[0.98]"
      >
        ⚡ Get My Free AI Audit Report
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  {/* Pricing */}
  <PricingSection />

  {/* Free Consultation CTA */}
  <section class="py-16 sm:py-20 bg-gradient-to-r from-brand-600 to-brand-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Start with a Free 1-Hour Consultation</h2>
      <p class="mt-4 text-lg text-brand-100 max-w-2xl mx-auto">
        No commitment. No sales pitch. We'll identify your biggest savings opportunity and give you a clear roadmap — based on real data from businesses like yours.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-brand-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-colors shadow-lg"
      >
        Book Your Free Session
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  {/* AI Chat */}
  <AIChat prompt="Ask me about AI consultation services..." placeholder="e.g. How much does a chatbot cost?" />

  {/* Structured data */}
  <script is:inline>
    document.head.insertAdjacentHTML('beforeend', `<script type="application/ld+json">${JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Business Simplifier",
          "url": "https://businesssimplifier.co.za",
          "description": "We help SMEs save R135K/year on average by streamlining processes with AI.",
          "slogan": "AI That Simplifies Your Business",
          "offers": [
            { "@type": "Offer", "name": "Free 1-Hour AI Consultation", "price": "0", "priceCurrency": "ZAR" },
            { "@type": "Offer", "name": "AI Chatbot Development", "price": "7500", "priceCurrency": "ZAR" },
            { "@type": "Offer", "name": "Business Process Automation", "price": "15000", "priceCurrency": "ZAR" }
          ]
        },
        {
          "@type": "WebSite",
          "name": "Business Simplifier",
          "url": "https://businesssimplifier.co.za",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://businesssimplifier.co.za/?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    })}</scr` + `ipt>`);
  </script>
</BaseLayout>