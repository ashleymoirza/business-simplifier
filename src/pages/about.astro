---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us" description="We're Business Simplifier — we help SMEs save R135K/year on average by streamlining processes with AI. Practical AI solutions for South African businesses.">
  <section class="bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">About Us</h1>
      <p class="mt-4 text-xl text-brand-100 max-w-2xl mx-auto">
        AI-native consultancy building practical AI solutions for real businesses.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto space-y-8 text-lg text-neutral-700 leading-relaxed">
        <p>
          <strong class="text-neutral-900">Business Simplifier</strong> was founded on a simple belief:
          artificial intelligence should be accessible to every business — not just the big tech companies
          with million-dollar budgets.
        </p>

        <p>
          We're an AI-native consultancy. That means we don't just <em>recommend</em> AI — we build everything
          using modern AI tools, delivering custom solutions in days instead of months, at a fraction of traditional
          development costs.
        </p>

        <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-6">
          <h3 class="text-xl font-bold text-neutral-900 mb-3">Our Approach</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-brand-600 font-bold shrink-0">1.</span>
              <span><strong class="text-neutral-900">Listen first</strong> — we start with a free 1-hour consultation to understand your business.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-600 font-bold shrink-0">2.</span>
              <span><strong class="text-neutral-900">Audit thoroughly</strong> — we identify the highest-impact AI opportunities for your specific context.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-600 font-bold shrink-0">3.</span>
              <span><strong class="text-neutral-900">Build fast</strong> — using modern AI development, we deliver working solutions in days, not months.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-600 font-bold shrink-0">4.</span>
              <span><strong class="text-neutral-900">Ensure adoption</strong> — we train your team and optimize post-launch.</span>
            </li>
          </ul>
        </div>

        <p>
          Our target markets are <strong class="text-neutral-900">South African SMEs</strong> (entry market) and
          <strong class="text-neutral-900">international businesses</strong> (scaling). We offer transparent,
          market-appropriate pricing for both.
        </p>

        <p>
          <strong class="text-neutral-900">Our differentiator?</strong> We're not a traditional dev agency that
          happens to use AI tools. We're an AI-native operation — we use the best AI tools available to deliver
          solutions faster, at better quality, and at a fraction of traditional costs.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>