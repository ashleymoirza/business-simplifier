---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuditTool from '../components/AuditTool.astro';
// Password baked in at build time — not visible in compiled output
const pagePassword = import.meta.env.AUDIT_PAGE_PASSWORD || 'changeme';
---

<BaseLayout
  title="AI Audit Tool — Internal"
  description="Internal AI audit tool."
  noIndex={true}
>

  <!-- ── PASSWORD GATE ── -->
  <!-- Wraps everything. Shows lock screen until correct password entered. -->
  <div x-data="auditGate()" x-init="check()" class="min-h-screen">

    <!-- Lock screen — shown until authenticated -->
    <div
      x-show="!unlocked"
      class="min-h-screen flex items-center justify-center bg-brand-950 px-4"
      style="display:none;"
    >
      <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-sm text-center">
        <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h1 class="text-xl font-bold text-neutral-900">Internal Tool</h1>
        <p class="mt-1 text-sm text-neutral-500">Enter your access password to continue.</p>

        <form @submit.prevent="attempt" class="mt-6 space-y-4">
          <input
            type="password"
            x-model="input"
            placeholder="Password"
            autocomplete="current-password"
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none text-center tracking-widest"
            autofocus
          />
          <p x-show="failed" class="text-sm text-red-600">Incorrect password. Try again.</p>
          <button
            type="submit"
            class="w-full py-3 px-6 text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-lg transition-colors"
          >
            Unlock
          </button>
        </form>
      </div>
    </div>

    <!-- Protected content — shown only when unlocked -->
    <div x-show="unlocked" style="display:none;">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 py-14 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-5 text-xs font-semibold text-accent-300 bg-accent-900/30 rounded-full border border-accent-700/30">
        <span class="w-1.5 h-1.5 bg-accent-400 rounded-full animate-pulse-subtle"></span>
        Free · Instant · No email required
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight">
        Your Free AI Audit Report
      </h1>
      <p class="mt-4 text-lg text-brand-100 max-w-2xl mx-auto leading-relaxed">
        Tell us about your business. Our AI analyses your industry, team size, and biggest pain points — then returns a personalised implementation plan with real ROI estimates.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-6 text-sm text-brand-300">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Personalised to your industry
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Real tool names + rand pricing
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Downloadable PDF report
        </span>
      </div>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-12 sm:py-16 bg-neutral-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <AuditTool />
    </div>
  </section>

  <!-- Setup instructions — password only -->
  <section class="py-12 bg-white border-t border-neutral-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-neutral-900 mb-2">Setting Your Audit Page Password</h2>
      <p class="text-sm text-neutral-600 mb-6">
        The audit tool runs entirely in your browser — no API, no external calls, no cost.
        The only setup needed is setting your access password.
      </p>

      <ol class="space-y-4 text-sm">
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-600 text-white rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <div>
            <p class="font-semibold text-neutral-800">Create a <code class="bg-neutral-100 px-1.5 py-0.5 rounded text-xs">.env</code> file</p>
            <p class="text-neutral-600 mt-0.5">In your <code class="bg-neutral-100 px-1.5 py-0.5 rounded text-xs">AI Consultation/</code> folder, create a file named <code class="bg-neutral-100 px-1.5 py-0.5 rounded text-xs">.env</code> containing:</p>
            <pre class="mt-2 bg-neutral-900 text-accent-300 text-xs px-4 py-3 rounded-lg overflow-x-auto">AUDIT_PAGE_PASSWORD=your-strong-password-here</pre>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-600 text-white rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <div>
            <p class="font-semibold text-neutral-800">Add the secret to GitHub</p>
            <p class="text-neutral-600 mt-0.5">GitHub repo → <strong>Settings → Secrets and variables → Actions → New repository secret</strong></p>
            <p class="text-neutral-600 mt-1">Name: <code class="bg-neutral-100 px-1.5 py-0.5 rounded text-xs">AUDIT_PAGE_PASSWORD</code> · Value: your chosen password</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-brand-600 text-white rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <div>
            <p class="font-semibold text-neutral-800">Push and redeploy</p>
            <p class="text-neutral-600 mt-0.5">Run <code class="bg-neutral-100 px-1.5 py-0.5 rounded text-xs">git add . && git commit -m "chore: set audit password" && git push</code> — GitHub Actions will rebuild with your password baked in.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Social proof strip -->
  <section class="py-10 bg-neutral-50 border-t border-neutral-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-neutral-500 mb-6">Trusted by SA businesses across 13 industries</p>
      <div class="flex flex-wrap justify-center gap-8 text-center">
        <div>
          <p class="text-2xl font-extrabold text-brand-700">40+</p>
          <p class="text-xs text-neutral-500 mt-0.5">Businesses audited</p>
        </div>
        <div>
          <p class="text-2xl font-extrabold text-brand-700">R135K</p>
          <p class="text-xs text-neutral-500 mt-0.5">Avg. annual saving</p>
        </div>
        <div>
          <p class="text-2xl font-extrabold text-brand-700">4–7x</p>
          <p class="text-xs text-neutral-500 mt-0.5">Average ROI</p>
        </div>
        <div>
          <p class="text-2xl font-extrabold text-brand-700">Free</p>
          <p class="text-xs text-neutral-500 mt-0.5">No commitment needed</p>
        </div>
      </div>
    </div>
  </section>

    </div>{/* end x-show="unlocked" */}
  </div>{/* end auditGate wrapper */}

</BaseLayout>

<script define:vars={{ pagePassword }}>
(function() {
  const CORRECT = pagePassword;
  const KEY = 'bs_audit_unlocked';

  window.auditGate = function() {
    return {
      unlocked: false,
      input: '',
      failed: false,

      check() {
        // Already authenticated this session?
        if (sessionStorage.getItem(KEY) === '1') {
          this.unlocked = true;
        }
      },

      attempt() {
        if (this.input === CORRECT) {
          sessionStorage.setItem(KEY, '1');
          this.unlocked = true;
          this.failed = false;
        } else {
          this.failed = true;
          this.input = '';
        }
      },
    };
  };
})();
</script>
