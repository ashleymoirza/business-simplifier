---
import BaseLayout from '../../layouts/BaseLayout.astro';
import services from '../../data/services';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;

if (!service) {
  return Astro.redirect('/services');
}
---

<BaseLayout
  title={service.title}
  description={service.description}
>
  <section class="bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-brand-200 mb-8">
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span>/</span>
        <span class="text-brand-300">{service.title}</span>
      </nav>
      <div class="max-w-3xl">
        <div class="text-5xl mb-4">{service.icon}</div>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white">{service.title}</h1>
        <p class="mt-3 text-xl text-brand-100">{service.tagline}</p>
        <p class="mt-6 text-lg text-brand-200/80 max-w-2xl">{service.description}</p>

        <div class="mt-8 flex flex-wrap items-center gap-6">
          <div class="bg-white/10 backdrop-blur-sm rounded-lg px-4 py-3">
            <span class="text-xs text-brand-300">SA Market</span>
            <p class="text-lg font-bold text-white">{service.priceSA}</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-lg px-4 py-3">
            <span class="text-xs text-brand-300">International</span>
            <p class="text-lg font-bold text-white">{service.priceIntl}</p>
          </div>
        </div>

        <p class="mt-4 text-sm text-brand-300 italic">{service.idealFor}</p>

        <a
          href={"/contact?service=" + service.id}
          class="mt-8 inline-flex items-center px-6 py-3 text-base font-semibold text-brand-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-colors"
        >
          {service.cta} &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-neutral-900 mb-6">What's Included</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {service.features.map((feature) => (
            <div class="flex items-start gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-100">
              <svg class="w-5 h-5 mt-0.5 text-accent-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-sm text-neutral-700">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 bg-gradient-to-r from-brand-600 to-brand-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to Get Started?</h2>
      <p class="mt-4 text-lg text-brand-100">Book your free 1-hour consultation today.</p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center px-6 py-3 text-base font-semibold text-brand-950 bg-accent-400 hover:bg-accent-300 rounded-lg transition-colors"
      >
        Free Consultation &rarr;
      </a>
    </div>
  </section>
</BaseLayout>