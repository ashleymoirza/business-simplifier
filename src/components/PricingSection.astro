---
import pricingTiers from '../data/pricing';
---

<section id="pricing" class="py-16 sm:py-20 bg-neutral-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-neutral-900">Simple, Transparent Pricing</h2>
      <p class="mt-4 text-lg text-neutral-600">
        SA-market pricing with international options. Start free, scale as you grow.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {pricingTiers.map((tier) => (
        <div
          class={`relative flex flex-col rounded-xl border p-6 ${
            tier.highlighted
              ? 'border-brand-500 bg-white shadow-lg ring-2 ring-brand-500/20'
              : 'border-neutral-200 bg-white'
          }`}
        >
          {tier.highlighted && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 text-xs font-semibold text-white bg-brand-600 rounded-full">
              Most Popular
            </span>
          )}

          <div class="mb-6">
            <h3 class="text-lg font-semibold text-neutral-900">{tier.name}</h3>
            <p class="mt-1 text-sm text-neutral-500">{tier.tagline}</p>
          </div>

          <div class="mb-6">
            <p class="text-3xl font-bold text-neutral-900">{tier.priceZA}</p>
            {tier.currencyZA && <p class="text-xs text-neutral-400">SA market ({tier.currencyZA})</p>}
            {tier.currencyIntl && <p class="text-xs text-neutral-400">International ({tier.currencyIntl})</p>}
          </div>

          <p class="text-sm text-neutral-600 mb-6">{tier.description}</p>

          <ul class="space-y-3 mb-8 flex-1">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 mt-0.5 text-accent-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="/contact"
            class={`w-full text-center py-2.5 rounded-lg text-sm font-semibold transition-colors ${
              tier.highlighted
                ? 'bg-brand-600 text-white hover:bg-brand-700 shadow-sm'
                : 'bg-neutral-100 text-neutral-700 hover:bg-neutral-200'
            }`}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>