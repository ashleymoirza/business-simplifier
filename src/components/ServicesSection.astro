---
import services from '../data/services';
---

<section id="services" class="py-16 sm:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-neutral-900">Our Services</h2>
      <p class="mt-4 text-lg text-neutral-600">
        From strategy to full integration — we meet you where you are.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div
          id={service.id}
          class="group relative bg-neutral-50 rounded-xl border border-neutral-200 p-6 hover:border-brand-300 hover:shadow-md transition-all"
        >
          <div class="text-3xl mb-4">{service.icon}</div>
          <h3 class="text-lg font-semibold text-neutral-900">{service.title}</h3>
          <p class="mt-1 text-sm text-brand-700 font-medium">{service.tagline}</p>
          <p class="mt-3 text-sm text-neutral-600 leading-relaxed">{service.description}</p>

          <ul class="mt-4 space-y-2">
            {service.features.slice(0, 3).map((feature) => (
              <li class="flex items-start gap-2 text-sm text-neutral-500">
                <svg class="w-4 h-4 mt-0.5 text-accent-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <div class="mt-6 pt-4 border-t border-neutral-200 flex items-center justify-between">
            <div>
              <span class="text-xs text-neutral-400">From</span>
              <p class="text-sm font-semibold text-neutral-800">{service.priceSA}</p>
            </div>
            <a
              href={"/contact?service=" + service.id}
              class="text-sm font-medium text-brand-600 hover:text-brand-700"
            >
              {service.cta} &rarr;
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>