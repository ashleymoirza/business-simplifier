---
import SITE_CONFIG from '../lib/seo';
---

<section class="py-16 sm:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-neutral-900">Get in Touch</h2>
      <p class="mt-4 text-lg text-neutral-600">
        Ready to start your AI journey? Book your free 1-hour consultation or send us a message.
      </p>
    </div>

    <div class="max-w-xl mx-auto">
      <form
        x-data="{
          name: '',
          email: '',
          company: '',
          service: 'strategy',
          message: '',
          submitted: false,
          error: '',
          async handleSubmit() {
            this.error = '';
            // Basic validation
            if (!this.name || !this.email || !this.message) {
              this.error = 'Please fill in all required fields.';
              return;
            }
            // In production, send to your form endpoint
            this.submitted = true;
          }
        }"
        @submit.prevent="handleSubmit"
        class="space-y-5"
      >
        {/* Success state */}
        <div x-show="submitted" x-cloak class="bg-green-50 border border-green-200 rounded-lg p-6 text-center">
          <svg class="w-12 h-12 mx-auto text-green-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <h3 class="text-lg font-semibold text-green-800">Thank You!</h3>
          <p class="mt-2 text-sm text-green-700">We'll be in touch within 24 hours to schedule your free consultation.</p>
        </div>

        {/* Form fields — hidden when submitted */}
        <div x-show="!submitted">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Name *</label>
              <input
                type="text" id="name" x-model="name" required
                class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email *</label>
              <input
                type="email" id="email" x-model="email" required
                class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
                placeholder="you@company.com"
              />
            </div>
          </div>

          <div class="mt-4">
            <label for="company" class="block text-sm font-medium text-neutral-700 mb-1">Company</label>
            <input
              type="text" id="company" x-model="company"
              class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
              placeholder="Your company name"
            />
          </div>

          <div class="mt-4">
            <label for="service" class="block text-sm font-medium text-neutral-700 mb-1">Service Interest</label>
            <select
              id="service" x-model="service"
              class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none bg-white"
            >
              <option value="strategy">AI Strategy (Free Consultation)</option>
              <option value="chatbot">AI Chatbot</option>
              <option value="automation">Process Automation</option>
              <option value="analytics">AI Analytics</option>
              <option value="content">Content Engine</option>
              <option value="fullstack">Full AI Integration</option>
            </select>
          </div>

          <div class="mt-4">
            <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Message *</label>
            <textarea
              id="message" x-model="message" required rows="4"
              class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
              placeholder="Tell us about your project or goals..."
            ></textarea>
          </div>

          <p x-show="error" x-text="error" class="mt-2 text-sm text-red-600"></p>

          <button
            type="submit"
            class="mt-6 w-full py-3 px-6 text-base font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-lg transition-colors shadow-sm"
          >
            Send Message
          </button>

          <p class="mt-3 text-xs text-neutral-400 text-center">
            Free 1-hour consultation included with every inquiry. No commitment required.
          </p>
        </div>
      </form>
    </div>
  </div>
</section>