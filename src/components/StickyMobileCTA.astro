---
// Sticky bottom CTA — visible only on mobile, hidden above md breakpoint
// Hides when user is near the top (hero CTA already visible)
---

<div
  x-data="{ visible: false }"
  x-init="
    window.addEventListener('scroll', () => {
      visible = window.scrollY > 300;
    }, { passive: true });
  "
  x-show="visible"
  x-transition:enter="transition ease-out duration-300 transform"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-200 transform"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 translate-y-4"
  class="fixed bottom-0 inset-x-0 z-40 md:hidden bg-white border-t border-neutral-200 shadow-xl px-4 py-3 safe-area-bottom"
  style="display: none;"
  aria-label="Book free consultation"
>
  <a
    href="/contact"
    class="flex items-center justify-center gap-2 w-full py-3 px-6 text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-colors shadow-sm"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    Book Free AI Consultation
  </a>
</div>
