---
// No API key needed — fully local rule-based engine + free website scanning
---

<div
  x-data="auditTool()"
  x-init="init()"
  class="max-w-3xl mx-auto"
>
  <!-- ── FORM STATE ── -->
  <div x-show="state === 'form'">
    <form @submit.prevent="runAudit" class="space-y-6">

      <!-- Company name + Industry -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="at-company" class="block text-sm font-medium text-neutral-700 mb-1">
            Company name <span class="text-red-500">*</span>
          </label>
          <input
            type="text" id="at-company" x-model="form.company" required
            placeholder="e.g. Acme Pty Ltd"
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
          />
        </div>
        <div>
          <label for="at-industry" class="block text-sm font-medium text-neutral-700 mb-1">
            Industry <span class="text-neutral-400 font-normal">(auto-detected if you enter a website)</span>
          </label>
          <select
            id="at-industry" x-model="form.industry"
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none bg-white"
          >
            <option value="">Select your industry…</option>
            <option>Healthcare</option>
            <option>Finance & Accounting</option>
            <option>E-commerce & Retail</option>
            <option>Education</option>
            <option>Real Estate & Property</option>
            <option>Legal</option>
            <option>Manufacturing</option>
            <option>Logistics & Transport</option>
            <option>Hospitality & Restaurants</option>
            <option>HR & Recruitment</option>
            <option>Marketing & Advertising</option>
            <option>Professional Services / Consulting</option>
            <option>Other</option>
          </select>
        </div>
      </div>

      <!-- Website URL — NEW -->
      <div>
        <label for="at-website" class="block text-sm font-medium text-neutral-700 mb-1">
          Company website
          <span class="text-neutral-400 font-normal">(optional — scans your site for smarter recommendations)</span>
        </label>
        <div class="relative">
          <input
            type="url" id="at-website" x-model="form.website"
            placeholder="https://yourcompany.co.za"
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none pr-10"
          />
          <!-- scanning spinner -->
          <div x-show="scanning" class="absolute right-3 top-1/2 -translate-y-1/2">
            <svg class="w-4 h-4 text-brand-500 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
            </svg>
          </div>
        </div>
        <!-- Scan status badge -->
        <p
          x-show="scanStatus"
          x-text="scanStatus"
          :class="scanSuccess ? 'text-green-700 bg-green-50 border-green-200' : 'text-amber-700 bg-amber-50 border-amber-200'"
          class="mt-2 text-xs px-3 py-1.5 rounded-lg border inline-flex items-center gap-1.5"
        ></p>
      </div>

      <!-- Employees + Revenue -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="at-size" class="block text-sm font-medium text-neutral-700 mb-1">
            Number of employees <span class="text-red-500">*</span>
          </label>
          <select
            id="at-size" x-model="form.size" required
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none bg-white"
          >
            <option value="">Select…</option>
            <option>1–10</option>
            <option>11–50</option>
            <option>51–200</option>
            <option>200+</option>
          </select>
        </div>
        <div>
          <label for="at-revenue" class="block text-sm font-medium text-neutral-700 mb-1">
            Monthly revenue (approximate)
          </label>
          <select
            id="at-revenue" x-model="form.revenue"
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none bg-white"
          >
            <option value="">Prefer not to say</option>
            <option>Under R50,000/month</option>
            <option>R50K – R200K/month</option>
            <option>R200K – R500K/month</option>
            <option>R500K – R2M/month</option>
            <option>Over R2M/month</option>
          </select>
        </div>
      </div>

      <!-- Pain points -->
      <div>
        <label for="at-pain" class="block text-sm font-medium text-neutral-700 mb-1">
          Describe your top 2–3 manual or time-consuming processes <span class="text-red-500">*</span>
        </label>
        <textarea
          id="at-pain" x-model="form.pain" required rows="4"
          placeholder="e.g. We manually answer 50+ WhatsApp messages per day. Invoice capturing takes 3 hours/week. Writing proposals takes a full day each..."
          class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none resize-none"
        ></textarea>
        <p class="mt-1 text-xs text-neutral-400">The more detail you give, the more specific the recommendations will be.</p>
      </div>

      <!-- Current tools -->
      <div>
        <label for="at-tools" class="block text-sm font-medium text-neutral-700 mb-1">
          What software/tools do you currently use? <span class="text-neutral-400 font-normal">(optional)</span>
        </label>
        <input
          type="text" id="at-tools" x-model="form.tools"
          placeholder="e.g. Xero, WhatsApp Business, Google Sheets, WordPress…"
          class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
        />
      </div>

      <!-- Primary goal -->
      <div>
        <label class="block text-sm font-medium text-neutral-700 mb-2">
          What's your primary goal? <span class="text-red-500">*</span>
        </label>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <template x-for="goal in goals" :key="goal.value">
            <label
              :class="form.goal === goal.value
                ? 'border-brand-600 bg-brand-50 text-brand-800'
                : 'border-neutral-200 bg-white text-neutral-700 hover:border-brand-300'"
              class="flex flex-col items-center gap-1.5 p-3 border-2 rounded-xl cursor-pointer transition-all text-center"
            >
              <input type="radio" :value="goal.value" x-model="form.goal" class="sr-only" />
              <span x-text="goal.icon" class="text-xl"></span>
              <span x-text="goal.label" class="text-xs font-medium leading-tight"></span>
            </label>
          </template>
        </div>
      </div>

      <!-- Error message -->
      <p x-show="error" x-text="error" class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3"></p>

      <!-- Submit -->
      <button
        type="submit"
        :disabled="scanning"
        class="w-full py-4 px-6 text-base font-bold text-white bg-brand-600 hover:bg-brand-700 disabled:opacity-60 disabled:cursor-not-allowed rounded-xl transition-colors shadow-md hover:shadow-lg"
      >
        <span x-show="!scanning">Generate My Free AI Audit Report →</span>
        <span x-show="scanning">Scanning website…</span>
      </button>

      <p class="text-center text-xs text-neutral-400">
        No email required. Results appear instantly. Your data is not stored.
      </p>
    </form>
  </div>

  <!-- ── LOADING STATE ── -->
  <div x-show="state === 'loading'" class="py-20 text-center">
    <div class="inline-flex flex-col items-center gap-6">
      <div class="relative w-16 h-16">
        <div class="absolute inset-0 rounded-full border-4 border-brand-100"></div>
        <div class="absolute inset-0 rounded-full border-4 border-brand-600 border-t-transparent animate-spin"></div>
      </div>
      <div>
        <p class="text-lg font-semibold text-neutral-800" x-text="loadingMessage"></p>
        <p class="mt-1 text-sm text-neutral-500">Building your personalised report…</p>
      </div>
      <div class="flex gap-2">
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-bounce" style="animation-delay:0s"></span>
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-bounce" style="animation-delay:0.15s"></span>
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-bounce" style="animation-delay:0.3s"></span>
      </div>
    </div>
  </div>

  <!-- ── REPORT STATE ── -->
  <div x-show="state === 'report'" id="audit-report" class="space-y-6">

    <!-- Report header -->
    <div class="bg-gradient-to-r from-brand-700 to-brand-900 rounded-2xl p-6 text-white">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <p class="text-brand-300 text-sm font-medium uppercase tracking-wide mb-1">AI Audit Report</p>
          <h2 class="text-2xl font-bold" x-text="form.company || 'Your Business'"></h2>
          <p class="text-brand-200 text-sm mt-1" x-text="(report.resolvedIndustry || form.industry) + ' · ' + form.size + ' employees'"></p>
        </div>
        <div class="text-right bg-white/10 rounded-xl px-5 py-3">
          <p class="text-brand-200 text-xs uppercase tracking-wide">Est. Annual Saving</p>
          <p class="text-3xl font-extrabold text-accent-400 mt-0.5" x-text="report.annualSaving || 'Calculating…'"></p>
        </div>
      </div>
      <p class="mt-4 text-brand-100 text-sm leading-relaxed" x-text="report.summary"></p>
    </div>

    <!-- ── WEBSITE INSIGHTS CARD (only shown if URL was provided) ── -->
    <div x-show="report.websiteInsights" class="bg-white border border-brand-200 rounded-xl p-5">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 w-9 h-9 bg-brand-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <h3 class="font-bold text-neutral-900 text-sm">Website Analysis</h3>
            <span class="text-xs text-neutral-400" x-text="report.websiteInsights && report.websiteInsights.url"></span>
          </div>

          <!-- Tech stack pills -->
          <div x-show="report.websiteInsights && report.websiteInsights.tech && report.websiteInsights.tech.length > 0" class="mt-2 flex flex-wrap gap-1.5">
            <span class="text-xs text-neutral-500 mr-1 self-center">Tech detected:</span>
            <template x-for="t in (report.websiteInsights && report.websiteInsights.tech || [])" :key="t">
              <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium bg-brand-100 text-brand-800 rounded-full" x-text="t"></span>
            </template>
          </div>
          <div x-show="report.websiteInsights && (!report.websiteInsights.tech || report.websiteInsights.tech.length === 0)" class="mt-2">
            <span class="text-xs text-neutral-500 bg-neutral-100 px-2 py-0.5 rounded-full">No major platforms detected</span>
          </div>

          <p class="mt-2.5 text-sm text-neutral-600 leading-relaxed" x-text="report.websiteInsights && report.websiteInsights.summary"></p>
        </div>
      </div>
    </div>

    <!-- Top AI Opportunities -->
    <div>
      <h3 class="text-lg font-bold text-neutral-900 mb-4">Your Top AI Opportunities</h3>
      <div class="space-y-4">
        <template x-for="(opp, i) in report.opportunities" :key="i">
          <div class="bg-white border border-neutral-200 rounded-xl p-5 hover:border-brand-300 hover:shadow-sm transition-all">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm font-bold" x-text="i + 1"></div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2 flex-wrap">
                  <h4 class="font-semibold text-neutral-900" x-text="opp.title"></h4>
                  <span
                    :class="{
                      'bg-green-100 text-green-800': opp.difficulty === 'Low',
                      'bg-yellow-100 text-yellow-800': opp.difficulty === 'Medium',
                      'bg-red-100 text-red-800': opp.difficulty === 'High'
                    }"
                    class="text-xs font-medium px-2 py-0.5 rounded-full flex-shrink-0"
                    x-text="opp.difficulty + ' effort'"
                  ></span>
                </div>
                <p class="mt-1.5 text-sm text-neutral-600 leading-relaxed" x-text="opp.description"></p>
                <div class="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3">
                  <div class="bg-neutral-50 rounded-lg p-2.5 text-center">
                    <p class="text-xs text-neutral-500">Recommended tool</p>
                    <p class="text-sm font-semibold text-brand-700 mt-0.5" x-text="opp.tool"></p>
                  </div>
                  <div class="bg-neutral-50 rounded-lg p-2.5 text-center">
                    <p class="text-xs text-neutral-500">Time saved</p>
                    <p class="text-sm font-semibold text-neutral-800 mt-0.5" x-text="opp.timeSaved"></p>
                  </div>
                  <div class="bg-neutral-50 rounded-lg p-2.5 text-center">
                    <p class="text-xs text-neutral-500">Setup cost</p>
                    <p class="text-sm font-semibold text-neutral-800 mt-0.5" x-text="opp.setupCost"></p>
                  </div>
                  <div class="bg-green-50 rounded-lg p-2.5 text-center">
                    <p class="text-xs text-green-600">Payback</p>
                    <p class="text-sm font-bold text-green-800 mt-0.5" x-text="opp.paybackWeeks + ' weeks'"></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </template>
      </div>
    </div>

    <!-- Quick Wins + Roadmap -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-accent-50 border border-accent-200 rounded-xl p-5">
        <h3 class="font-bold text-neutral-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Quick Wins — This Week
        </h3>
        <ul class="space-y-2">
          <template x-for="(win, i) in report.quickWins" :key="i">
            <li class="flex items-start gap-2 text-sm text-neutral-700">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span x-text="win"></span>
            </li>
          </template>
        </ul>
      </div>

      <div class="bg-brand-50 border border-brand-200 rounded-xl p-5">
        <h3 class="font-bold text-neutral-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          Your 90-Day Roadmap
        </h3>
        <div class="space-y-3">
          <div class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-600 text-white rounded-full flex items-center justify-center text-xs font-bold">1</span>
            <div>
              <p class="text-xs font-semibold text-brand-700 uppercase tracking-wide">Month 1</p>
              <p class="text-sm text-neutral-700 mt-0.5" x-text="report.roadmap && report.roadmap.month1"></p>
            </div>
          </div>
          <div class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-500 text-white rounded-full flex items-center justify-center text-xs font-bold">2</span>
            <div>
              <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Month 2</p>
              <p class="text-sm text-neutral-700 mt-0.5" x-text="report.roadmap && report.roadmap.month2"></p>
            </div>
          </div>
          <div class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-400 text-white rounded-full flex items-center justify-center text-xs font-bold">3</span>
            <div>
              <p class="text-xs font-semibold text-brand-500 uppercase tracking-wide">Month 3</p>
              <p class="text-sm text-neutral-700 mt-0.5" x-text="report.roadmap && report.roadmap.month3"></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA bar -->
    <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-2xl p-6 text-center text-white">
      <h3 class="text-xl font-bold">Ready to implement this plan?</h3>
      <p class="mt-2 text-brand-100 text-sm max-w-lg mx-auto">
        Book your free 1-hour consultation. We'll walk through this report together and give you a clear implementation timeline, exact costs, and a step-by-step action plan.
      </p>
      <div class="mt-5 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-bold text-brand-950 bg-accent-400 hover:bg-accent-300 rounded-xl transition-colors shadow-lg"
        >
          Book Free Consultation
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <button
          @click="downloadReport()"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white border-2 border-white/40 hover:border-white hover:bg-white/10 rounded-xl transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Download PDF Report
        </button>
      </div>
    </div>

    <!-- Start over -->
    <div class="text-center">
      <button
        @click="reset()"
        class="text-sm text-neutral-500 hover:text-neutral-700 underline underline-offset-2 transition-colors"
      >
        ← Run another audit
      </button>
    </div>
  </div>
</div>

<script>
(function() {

  // ─────────────────────────────────────────────────────────────────────────
  // INDUSTRY KNOWLEDGE BASE
  // ─────────────────────────────────────────────────────────────────────────
  const INDUSTRY_DATA = {
    'Healthcare': {
      saving: { '1–10': 'R68,000', '11–50': 'R145,000', '51–200': 'R280,000', '200+': 'R520,000' },
      summary: (c) => `${c} operates in one of SA's highest-admin industries — the average practice wastes 35% of staff time on paperwork, appointment management, and follow-ups that AI can fully automate. Based on your team size and pain points, we've identified the highest-ROI opportunities below.`,
      opportunities: [
        { title: 'AI Appointment Scheduling & Reminders', description: 'Automate booking confirmations, 24-hour reminders, and no-show follow-ups via WhatsApp. Reduces no-shows by up to 40% and frees reception staff from manual calling.', tool: 'Appointlet + WhatsApp Business API', timeSaved: '18 hrs/month', setupCost: 'R4,500', monthlyCost: 'R650', paybackWeeks: 5, difficulty: 'Low' },
        { title: 'Automated Patient Intake Forms', description: 'Replace paper forms with digital intake that auto-populates your practice management system. Eliminates data capturing errors and 30+ minutes of admin per new patient.', tool: 'Typeform + Zapier', timeSaved: '12 hrs/month', setupCost: 'R3,200', monthlyCost: 'R480', paybackWeeks: 7, difficulty: 'Low' },
        { title: 'AI Medical Scribing & Notes', description: 'Transcribe and summarise consultation notes automatically. Cuts post-consultation admin from 15 minutes to under 3 minutes per patient.', tool: 'Nabla Copilot', timeSaved: '25 hrs/month', setupCost: 'R6,000', monthlyCost: 'R1,200', paybackWeeks: 9, difficulty: 'Medium' },
      ],
      quickWins: [
        'Set up WhatsApp Business auto-replies for common patient questions (free, takes 30 minutes)',
        'Use Google Forms + Google Sheets to digitise intake forms this week at zero cost',
        'Enable Google Calendar automated reminders — reduce no-shows immediately for free',
      ],
      roadmap: { month1: 'Deploy WhatsApp appointment reminders and digital intake forms', month2: 'Integrate booking system with automated confirmation and follow-up flows', month3: 'Implement AI scribing for consultation notes to reclaim 25+ hours/month' },
    },
    'Finance & Accounting': {
      saving: { '1–10': 'R92,000', '11–50': 'R178,000', '51–200': 'R340,000', '200+': 'R680,000' },
      summary: (c) => `${c} handles high volumes of repetitive financial data — exactly where AI delivers the fastest ROI. SA accounting firms using automation report saving 60–80% of time on data entry, reconciliation, and report generation.`,
      opportunities: [
        { title: 'Automated Invoice Capture & Coding', description: 'AI reads supplier invoices (email, photo, PDF) and posts them to your accounting system with correct GL coding. Eliminates manual data entry and reduces processing time from minutes to seconds per invoice.', tool: 'Dext (Receipt Bank)', timeSaved: '22 hrs/month', setupCost: 'R2,800', monthlyCost: 'R890', paybackWeeks: 4, difficulty: 'Low' },
        { title: 'AI Bank Reconciliation', description: 'Automatically match bank transactions to invoices and receipts. What currently takes hours per week runs in minutes with near-100% match accuracy.', tool: 'Xero AI Reconciliation', timeSaved: '16 hrs/month', setupCost: 'R1,500', monthlyCost: 'R620', paybackWeeks: 5, difficulty: 'Low' },
        { title: 'Automated Financial Reporting', description: 'Generate monthly management accounts, cash flow forecasts, and client reports automatically from your accounting data. Deliver professional reports in minutes instead of days.', tool: 'Fathom HQ', timeSaved: '20 hrs/month', setupCost: 'R3,500', monthlyCost: 'R750', paybackWeeks: 8, difficulty: 'Medium' },
      ],
      quickWins: [
        'Enable Xero\'s built-in bank feed auto-matching — free if you already use Xero',
        'Use Hubdoc (free with Xero) to auto-fetch bank and supplier statements',
        'Set up email rules to auto-sort invoices into folders before processing — free, saves 2 hrs/week',
      ],
      roadmap: { month1: 'Implement Dext for automated invoice capture across all suppliers', month2: 'Connect bank feeds and enable AI reconciliation in Xero or Sage', month3: 'Deploy Fathom for automated client reporting and cash flow forecasting' },
    },
    'E-commerce & Retail': {
      saving: { '1–10': 'R75,000', '11–50': 'R155,000', '51–200': 'R310,000', '200+': 'R590,000' },
