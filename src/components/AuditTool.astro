    const [textResult, techResult] = await Promise.allSettled([
      // A — homepage text via CORS proxy
      fetchWithTimeout(`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`, 7000)
        .then(r => r.json())
        .then(d => {
          if (!d || !d.contents) return '';
          return d.contents
            .replace(/<style[^>]*>[\s\S]*?<\/style>/gi, ' ')
            .replace(/<script[^>]*>[\s\S]*?<\/script>/gi, ' ')
            .replace(/<[^>]+>/g, ' ')
            .replace(/\s+/g, ' ')
            .slice(0, 4000)
            .toLowerCase();
        }),
      // B — tech stack via BuiltWith free API
      fetchWithTimeout(`https://api.builtwith.com/free1/api.json?KEY=free&LOOKUP=${domain}`, 7000)
        .then(r => r.json())
        .then(d => {
          const paths = d?.Results?.[0]?.Result?.Paths;
          if (!paths || !paths.length) return [];
          const all = [];
          paths.forEach(p => (p.Technologies || []).forEach(t => { if (t.Name) all.push(t.Name); }));
          return [...new Set(all)];
        }),
    ]);

    if (textResult.status === 'fulfilled') text = textResult.value || '';
    if (techResult.status === 'fulfilled') tech = techResult.value || [];

    return { text, tech, domain };
  }

  // ─────────────────────────────────────────────────────────────────────────
  // WEBSITE SIGNALS EXTRACTION
  // ─────────────────────────────────────────────────────────────────────────
  function extractWebsiteSignals(websiteData) {
    const { text, tech, domain } = websiteData;

    // Inject tech-based keywords
    const injectedKeywords = [];
    tech.forEach(t => {
      const mapped = TECH_KEYWORD_MAP[t];
      if (mapped) injectedKeywords.push(...mapped);
    });

    // Detect keywords in page text
    const allKeywords = Object.keys(PAIN_KEYWORDS);
    const detectedKeywords = allKeywords.filter(k => text.includes(k));

    // Auto-detect industry from page text
    let suggestedIndustry = '';
    let bestScore = 0;
    INDUSTRY_SIGNALS.forEach(({ keywords, industry }) => {
      const score = keywords.filter(k => text.includes(k)).length;
      if (score > bestScore) {
        bestScore = score;
        suggestedIndustry = industry;
      }
    });
    if (bestScore < 2) suggestedIndustry = ''; // require at least 2 matching keywords

    // Known tech to show in report (filter to recognisable names)
    const knownTech = tech.filter(t => Object.keys(TECH_KEYWORD_MAP).includes(t)).slice(0, 6);

    // Build summary sentence
    let websiteSummary = '';
    if (knownTech.length > 0) {
      websiteSummary = `${domain} already runs ${knownTech.join(', ')} — recommendations have been tailored to work with your existing stack and highlight the highest-value additions.`;
    } else if (text.length > 100) {
      websiteSummary = `We scanned ${domain} and analysed your business focus. Recommendations below are personalised based on your website content.`;
    } else {
      websiteSummary = `We attempted to scan ${domain} but could not extract detailed content. Recommendations are based on your manual inputs.`;
    }

    return {
      detectedTools: knownTech,
      detectedKeywords: [...new Set([...detectedKeywords, ...injectedKeywords])],
      suggestedIndustry,
      websiteSummary,
    };
  }

  // ─────────────────────────────────────────────────────────────────────────
  // REPORT GENERATION ENGINE
  // ─────────────────────────────────────────────────────────────────────────
  function generateReport(form, websiteData) {
    let signals = null;
    if (websiteData) {
      signals = extractWebsiteSignals(websiteData);
    }

    // Resolve industry: manual selection > website auto-detection > 'Other'
    const resolvedIndustry = form.industry
      || (signals && signals.suggestedIndustry)
      || 'Other';

    const industryKey = INDUSTRY_DATA[resolvedIndustry] ? resolvedIndustry : 'Other';
    const data = INDUSTRY_DATA[industryKey];

    // Build the keyword string from pain points + tools + website signals
    let painLower = (form.pain + ' ' + form.tools).toLowerCase();
    if (signals) {
      painLower += ' ' + signals.detectedKeywords.join(' ');
    }

    // Deep clone opportunities
    let opps = data.opportunities.map(o => ({ ...o }));

    // Apply pain-point keyword overrides
    Object.entries(PAIN_KEYWORDS).forEach(([keyword, override]) => {
      if (painLower.includes(keyword) && opps[override.boost]) {
        opps[override.boost] = {
          ...opps[override.boost],
          title: override.newTitle,
          tool: override.newTool,
        };
      }
    });

    // Personalise descriptions
    opps = opps.map(o => ({
      ...o,
      description: o.description.replace('your business', form.company || 'your business'),
    }));

    // Scale saving
    const baseSaving = data.saving[form.size] || data.saving['1–10'];
    const multiplier = GOAL_MULTIPLIERS[form.goal] || 1.0;
    const numericBase = parseInt(baseSaving.replace(/[^0-9]/g, ''), 10);
    const adjustedNum = Math.round((numericBase * multiplier) / 1000) * 1000;
    const annualSaving = 'R' + adjustedNum.toLocaleString('en-ZA');

    const report = {
      summary: data.summary(form.company || 'Your business'),
      annualSaving,
      resolvedIndustry,
      opportunities: opps,
      quickWins: data.quickWins,
      roadmap: data.roadmap,
    };

    // Add website insights if we have them
    if (signals && form.website) {
      report.websiteInsights = {
        url: websiteData.domain || form.website,
        tech: signals.detectedTools,
        summary: signals.websiteSummary,
      };
    }

    return report;
  }

  // ─────────────────────────────────────────────────────────────────────────
  // ALPINE COMPONENT
  // ─────────────────────────────────────────────────────────────────────────
  window.auditTool = function() {
    return {
      state: 'form',
      error: '',
      scanning: false,
      scanStatus: '',
      scanSuccess: false,
      websiteData: null,
      loadingMessage: LOADING_MESSAGES[0],
      loadingInterval: null,
      report: {},
      form: {
        company: '',
        industry: '',
        size: '',
        revenue: '',
        pain: '',
        tools: '',
        goal: 'save-time',
        website: '',
      },
      goals: [
        { value: 'cut-costs',    label: 'Cut costs',                   icon: '💰' },
        { value: 'save-time',    label: 'Save time',                   icon: '⏱️' },
        { value: 'grow-revenue', label: 'Grow revenue',                icon: '📈' },
        { value: 'improve-cx',   label: 'Better customer experience',  icon: '⭐' },
      ],

      init() {
        this.form.goal = 'save-time';
      },

      async runAudit() {
        if (!this.form.company || !this.form.size || !this.form.pain) {
          this.error = 'Please fill in all required fields (marked with *).';
          return;
        }
        if (!this.form.industry && !this.form.website) {
          this.error = 'Please select an industry or enter your website URL so we can auto-detect it.';
          return;
        }
        this.error = '';

        // ── Step 1: scan website if URL provided ──
        let websiteData = null;
        if (this.form.website) {
          this.scanning = true;
          this.scanStatus = '';
          try {
            websiteData = await scanWebsite(this.form.website);
            if (websiteData) {
              const signals = extractWebsiteSignals(websiteData);
              const techList = signals.detectedTools;
              if (techList.length > 0) {
                this.scanStatus = '✓ ' + techList.join(' · ') + ' detected — recommendations tailored';
                this.scanSuccess = true;
              } else {
                this.scanStatus = '✓ Website scanned — content analysed';
                this.scanSuccess = true;
              }
              // Auto-fill industry if blank
              if (!this.form.industry && signals.suggestedIndustry) {
                this.form.industry = signals.suggestedIndustry;
              }
            } else {
              this.scanStatus = '⚠ Could not scan website — report based on your inputs';
              this.scanSuccess = false;
            }
          } catch {
            this.scanStatus = '⚠ Could not scan website — report based on your inputs';
            this.scanSuccess = false;
          }
          this.scanning = false;
          this.websiteData = websiteData;
        }

        // ── Step 2: loading animation ──
        this.state = 'loading';
        let msgIdx = 0;
        this.loadingMessage = LOADING_MESSAGES[0];
        this.loadingInterval = setInterval(() => {
          msgIdx = (msgIdx + 1) % LOADING_MESSAGES.length;
          this.loadingMessage = LOADING_MESSAGES[msgIdx];
        }, 900);

        // ── Step 3: generate report ──
        const formSnapshot = { ...this.form };
        const wdSnapshot = this.websiteData;
        setTimeout(() => {
          clearInterval(this.loadingInterval);
          try {
            this.report = generateReport(formSnapshot, wdSnapshot);
            this.state = 'report';
            this.$nextTick(() => {
              const el = document.getElementById('audit-report');
              if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          } catch (e) {
            this.state = 'form';
            this.error = 'Something went wrong generating the report. Please try again.';
          }
        }, 2400);
      },

      downloadReport() {
        window.print();
      },

      reset() {
        clearInterval(this.loadingInterval);
        this.state = 'form';
        this.report = {};
        this.error = '';
        this.scanStatus = '';
        this.scanSuccess = false;
        this.websiteData = null;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      },
    };
  };
})();
</script>

