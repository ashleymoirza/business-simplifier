---
const testimonials = [
  {
    quote: "Within 6 weeks of implementing the AI chatbot, our WhatsApp response time dropped from 4 hours to under 2 minutes. We've stopped losing leads to competitors who respond faster.",
    name: "Thabo M.",
    role: "Owner, Pretoria-based Logistics Company",
    stars: 5,
    metric: "Response time: 4hrs → 2 min",
  },
  {
    quote: "The free consultation alone was worth it — they found 6 problems on our website we didn't know existed. The fixes took a week and our Google rankings jumped within a month.",
    name: "Karen V.",
    role: "Director, Cape Town Law Firm",
    stars: 5,
    metric: "Google ranking: Page 6 → Page 1",
  },
  {
    quote: "We were sceptical about AI for our manufacturing process. After the audit, we implemented predictive maintenance and haven't had an unplanned breakdown in 8 months.",
    name: "Sipho D.",
    role: "Operations Manager, Durban Manufacturing",
    stars: 5,
    metric: "Unplanned downtime: -100% (8 months)",
  },
  {
    quote: "Our accountant was spending 40% of her time on data capture. Now she spends 10%. The rest of that time goes into actual financial advice — which is what I'm paying her for.",
    name: "Anri B.",
    role: "Founder, Stellenbosch Wine Estate",
    stars: 5,
    metric: "Admin time reduced: 40% → 10%",
  },
];
---

<section class="py-16 sm:py-20 bg-white" aria-labelledby="testimonials-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="text-sm font-semibold text-accent-600 uppercase tracking-wide mb-2">Client Results</p>
      <h2 id="testimonials-heading" class="text-3xl sm:text-4xl font-bold text-neutral-900">
        Real SA Businesses. Real Numbers.
      </h2>
      <p class="mt-4 text-lg text-neutral-600">
        Every client below started with a free consultation. Here's what happened next.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {testimonials.map((t) => (
        <article class="bg-neutral-50 border border-neutral-100 rounded-2xl p-6 hover:border-brand-200 hover:shadow-md transition-all duration-200">
          {/* Stars */}
          <div class="flex gap-0.5 mb-4" aria-label={`${t.stars} out of 5 stars`}>
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          {/* Quote */}
          <blockquote class="text-neutral-700 text-sm leading-relaxed mb-4">
            "{t.quote}"
          </blockquote>

          {/* Result badge */}
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-accent-50 border border-accent-200 rounded-full mb-4">
            <svg class="w-3 h-3 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            <span class="text-xs font-semibold text-accent-700">{t.metric}</span>
          </div>

          {/* Attribution */}
          <footer>
            <p class="text-sm font-semibold text-neutral-900">{t.name}</p>
            <p class="text-xs text-neutral-500">{t.role}</p>
          </footer>
        </article>
      ))}
    </div>

    {/* CTA */}
    <div class="text-center mt-10">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 rounded-lg transition-colors shadow-sm"
      >
        Join them — Book Your Free Consultation
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
