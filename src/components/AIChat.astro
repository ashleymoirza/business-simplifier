---
import faqs from '../data/faqData';
const faqJson = JSON.stringify(faqs);
---

<div
  x-data="chatState()"
  class="fixed bottom-6 right-6 z-40"
>
  {/* Embedded FAQ data for the script to read */}
  <script id="faq-data" type="application/json" set:html={faqJson}></script>

  {/* Chat button */}
  <button
    @click="open = !open"
    class="w-14 h-14 rounded-full bg-brand-600 hover:bg-brand-700 text-white shadow-lg flex items-center justify-center transition-all hover:scale-105 active:scale-95"
    aria-label="Toggle AI chat"
  >
    <svg x-show="!open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    <svg x-show="open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  {/* Chat window */}
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 translate-y-4 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 translate-y-4 scale-95"
    class="absolute bottom-16 right-0 w-80 sm:w-96 bg-white rounded-xl shadow-2xl border border-neutral-200 overflow-hidden"
  >
    {/* Header */}
    <div class="bg-brand-700 text-white px-4 py-3 flex items-center gap-2">
      <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse-subtle"></span>
      <span class="text-sm font-semibold">Business Simplifier</span>
    </div>

    {/* Messages */}
    <div class="h-80 overflow-y-auto p-4 space-y-3" x-ref="msgs">
      {/* Welcome message */}
      <div x-show="messages.length === 0" class="text-center py-4">
        <p class="text-sm text-neutral-500 mb-3">Hi! I can answer questions about AI services, pricing, industries, and more.</p>
        <p class="text-xs text-neutral-400 mb-3">Try asking:</p>
        <div class="flex flex-wrap justify-center gap-2">
          <button @click="askSuggested('How much does AI consulting cost?')" class="text-xs px-3 py-1.5 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors cursor-pointer">Pricing</button>
          <button @click="askSuggested('How can AI help healthcare?')" class="text-xs px-3 py-1.5 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors cursor-pointer">Healthcare</button>
          <button @click="askSuggested('What is the free consultation?')" class="text-xs px-3 py-1.5 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors cursor-pointer">Free session</button>
          <button @click="askSuggested('How long does a project take?')" class="text-xs px-3 py-1.5 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors cursor-pointer">Timeline</button>
          <button @click="askSuggested('Can AI help e-commerce?')" class="text-xs px-3 py-1.5 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors cursor-pointer">E-commerce</button>
          <button @click="askSuggested('Do I need technical knowledge?')" class="text-xs px-3 py-1.5 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors cursor-pointer">Tech needed?</button>
        </div>
      </div>

      {/* Messages loop */}
      <template x-for="(msg, i) in messages" :key="i">
        <div :class="msg.role === 'user' ? 'text-right' : 'text-left'">
          <div
            :class="msg.role === 'user' ? 'bg-brand-600 text-white ml-8' : 'bg-neutral-100 text-neutral-800 mr-8'"
            class="inline-block px-3.5 py-2 rounded-lg text-sm text-left max-w-[85%] leading-relaxed"
          >
            <p x-text="msg.content" class="whitespace-pre-line"></p>
            <template x-if="msg.role === 'assistant' && msg.suggested">
              <div class="mt-2 pt-2 border-t border-neutral-300/50">
                <p class="text-xs text-neutral-500 mb-1.5">Was this helpful?</p>
                <a href="/contact" class="inline-block text-xs font-medium text-brand-600 hover:text-brand-700">
                  Book a free consultation &rarr;
                </a>
              </div>
            </template>
          </div>
        </div>
      </template>

      {/* Loading dots */}
      <div x-show="loading" class="flex items-center gap-2 text-sm text-neutral-400 pl-2">
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-bounce"></span>
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></span>
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
      </div>
    </div>

    {/* Input */}
    <div class="border-t border-neutral-200 p-3">
      <form @submit.prevent="sendMessage" class="flex gap-2">
        <input
          type="text" x-model="input"
          placeholder="Ask about AI services..."
          class="flex-1 px-3 py-2 text-sm border border-neutral-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
        />
        <button
          type="submit"
          class="px-3 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-lg transition-colors disabled:opacity-50"
          :disabled="loading || !input.trim()"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19V5m0 0l-7 7m7-7l7 7"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  var FAQ_DATA = [];
  try {
    var el = document.getElementById('faq-data');
    if (el) FAQ_DATA = JSON.parse(el.textContent);
  } catch(e) {}

  function findBestMatch(query) {
    if (!query || query.trim().length < 2) return null;
    var words = query.toLowerCase().split(/\s+/).filter(function(w) { return w.length > 2; });
    if (words.length === 0) return null;
    var bestScore = 0, bestFaq = null;
    for (var i = 0; i < FAQ_DATA.length; i++) {
      var faq = FAQ_DATA[i];
      var score = 0;
      for (var j = 0; j < words.length; j++) {
        var word = words[j];
        for (var k = 0; k < faq.keywords.length; k++) {
          var kw = faq.keywords[k];
          if (kw.indexOf(word) !== -1) score += 3;
          if (word.indexOf(kw) !== -1 || kw.indexOf(word) !== -1) score += 2;
        }
        if (faq.question.toLowerCase().indexOf(word) !== -1) score += 1;
        if (faq.answer.toLowerCase().indexOf(word) !== -1) score += 0.5;
      }
      if (score > bestScore) { bestScore = score; bestFaq = faq; }
    }
    return bestScore >= 3 ? bestFaq : null;
  }

  window.chatState = function() {
    return {
      open: false,
      messages: [],
      input: '',
      loading: false,
      sendMessage: function() {
        var self = this;
        if (!self.input.trim() || self.loading) return;
        var userMsg = self.input.trim();
        self.messages.push({ role: 'user', content: userMsg });
        self.input = '';
        self.loading = true;
        setTimeout(function() {
          var match = findBestMatch(userMsg);
          if (match) {
            self.messages.push({ role: 'assistant', content: match.answer, suggested: true });
          } else {
            self.messages.push({
              role: 'assistant',
              content: 'I am not sure about that specifically. Try asking about pricing, services, industries, or our free consultation. Or book a free 1-hour session and we will answer all your questions.',
              suggested: false
            });
          }
          self.loading = false;
          self.$nextTick(function() {
            var c = self.$refs.msgs;
            if (c) c.scrollTop = c.scrollHeight;
          });
        }, 600);
      },
      askSuggested: function(q) { this.input = q; this.sendMessage(); }
    };
  };
})();
</script>